{
  "Routes": [
    {
      "UpstreamPathTemplate": "/api/identity/{everything}",
      "UpstreamMethods": [ "Get", "Post", "Put", "Delete", "Options" ],
      "DownstreamPathTemplate": "/api/identity/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5001 }
      ]
    },
    {
      "UpstreamPathTemplate": "/api/incidents/{everything}",
      "UpstreamMethods": [ "Get", "Post", "Put", "Delete", "Options" ],
      "DownstreamPathTemplate": "/api/incidents/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5003 }
      ]
    },
    {
      "UpstreamPathTemplate": "/api/incidents",
      "UpstreamMethods": [ "Get", "Post", "Options" ],
      "DownstreamPathTemplate": "/api/incidents",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5003 }
      ]
    },
    {
      "UpstreamPathTemplate": "/hubs/alerts/negotiate",
      "UpstreamMethods": [ "Post", "Options" ],
      "DownstreamPathTemplate": "/hubs/alerts/negotiate",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5003 }
      ]
    },
    {
      "UpstreamPathTemplate": "/hubs/alerts",
      "UpstreamMethods": [ "Get" ],
      "DownstreamPathTemplate": "/hubs/alerts",
      "DownstreamScheme": "ws",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5003 }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000"
  }
}
